{
  "name": "2.5d-indoor-maps",
  "version": "1.2.0",
  "description": "A 2.5D indoor mapping tool using OpenStreetMap data for accessible and intuitive multi-floor navigation.",
  "main": "dist/server/index.js",
  "engines": {
    "node": ">=24.17.0",
    "npm": ">=11"
  },
  "scripts": {
    "dev": "npm run build:client:dev && npm run build:server && concurrently -k -n client,server,app -c blue,magenta,green \"npm:watch:client\" \"npm:watch:server\" \"npm:serve:watch\"",
    "build": "npm run build:client && npm run build:server",
    "build:client": "webpack --mode production",
    "build:client:dev": "webpack --mode development",
    "watch:client": "webpack --mode development --watch",
    "watch:server": "tsc -p tsconfig.server.json --watch --preserveWatchOutput",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "npm run build && npm run serve",
    "serve": "node dist/server/index.js",
    "serve:watch": "node --watch dist/server/index.js",
    "test": "jest",
    "test:e2e": "node scripts/runPlaywright.mjs",
    "test:coverage": "jest --coverage",
    "format": "prettier . --write",
    "check:format": "prettier . --check",
    "lint": "eslint . --ext .ts",
    "check:config": "node scripts/validateConfig.mjs",
    "typecheck": "tsc --noEmit && npm run typecheck:server",
    "typecheck:server": "tsc --noEmit -p tsconfig.server.json",
    "typecheck:strict": "tsc --noEmit -p tsconfig.strict.json",
    "analyze:stats": "webpack --mode production --profile --json=tmp/webpack-stats.json",
    "analyze": "npm run analyze:stats && webpack-bundle-analyzer tmp/webpack-stats.json",
    "check:bundle": "node scripts/checkBundleBudget.mjs",
    "check": "npm run check:config && npm run check:format && npm run lint && npm run typecheck && npm test -- --runInBand && npm run build && npm run check:bundle && npm run test:e2e"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:Accessible-InfoPoint/2.5D-Indoor-Maps.git"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fontsource/material-icons": "^5.2.7",
    "bbox-fns": "^0.20.2",
    "bootstrap": "^5.3.8",
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "geojson-bounds": "^1.0.4",
    "geojson-polygon-center": "^0.0.0",
    "jimp": "^1.6.1",
    "maplibre-gl": "^5.24.0",
    "osm2geojson-ultra": "^4.0.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "three": "^0.175.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "@types/bootstrap": "^5.2.11",
    "@types/compression": "^1.8.1",
    "@types/geojson": "^7946.0.16",
    "@types/jest": "^30.0.0",
    "@types/three": "^0.175.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.61.1",
    "ajv": "^8.20.0",
    "concurrently": "^10.0.3",
    "css-loader": "^7.1.4",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "eslint": "^10.6.0",
    "file-loader": "^6.2.0",
    "globals": "^16.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "mini-css-extract-plugin": "^2.10.2",
    "prettier": "^3.9.4",
    "sass-embedded": "^1.100.0",
    "sass-loader": "^17.0.0",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.2",
    "typescript": "^6.0.3",
    "webpack": "^5.107.2",
    "webpack-bundle-analyzer": "^5.3.0",
    "webpack-cli": "^6.0.1"
  }
}
