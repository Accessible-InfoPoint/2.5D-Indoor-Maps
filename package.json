{
  "name": "2.5d-indoor-maps",
  "version": "1.0.0",
  "description": "A 2.5D indoor mapping tool using OpenStreetMap data for accessible and intuitive multi-floor navigation.",
  "main": "dist/server/index.js",
  "scripts": {
    "build": "npm run build:client && npm run build:server",
    "build:client": "webpack",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "npm run build && npm run serve",
    "serve": "node dist/server/index.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit && npm run typecheck:server",
    "typecheck:server": "tsc --noEmit -p tsconfig.server.json",
    "typecheck:strict": "tsc --noEmit -p tsconfig.strict.json",
    "build-start": "npm start"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:Accessible-InfoPoint/2.5D-Indoor-Maps.git"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bbox-fns": "^0.20.2",
    "bootstrap": "^5.3.8",
    "express": "^5.2.1",
    "geojson-bounds": "^1.0.4",
    "geojson-polygon-center": "^0.0.0",
    "jimp": "^1.6.1",
    "maptalks": "^1.0.5",
    "maptalks.three": "^0.40.1",
    "osmtogeojson": "https://github.com/tyrasd/osmtogeojson#snyk-fix-65371a4c4920389f7e5127c141088511",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "three": "^0.175.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@types/bootstrap": "^5.2.10",
    "@types/geojson": "^7946.0.16",
    "@types/jest": "^29.5.14",
    "@types/maptalks": "^0.49.6",
    "@types/three": "^0.175.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "css-loader": "^7.1.4",
    "eslint": "^9.39.4",
    "file-loader": "^6.2.0",
    "globals": "^16.0.0",
    "jest": "^28.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "sass-embedded": "^1.100.0",
    "sass-loader": "^16.0.8",
    "style-loader": "^4.0.0",
    "ts-jest": "^28.0.0",
    "ts-loader": "^9.6.2",
    "typescript": "^6.0.3",
    "webpack": "^5.107.2",
    "webpack-cli": "^6.0.1"
  }
}
